{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/realtime/:path*",
      "destination": "http://112.213.91.235:3005/realtime/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "http://112.213.91.235:3005/socket.io/:path*"
    },
    {
      "source": "/service/:path*",
      "destination": "https://stocktraders.vn/service/:path*"
    },
    {
      "source": "/api/portfolio-chat",
      "destination": "http://112.213.91.235:8000/api/portfolio-chat"
    }
  ]
}
